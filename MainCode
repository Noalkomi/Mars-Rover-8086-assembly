data segment
    uniid    db 8 dup(0)
    uniid2   db 8 dup(0)
    row      db 6 dup(?)
    col      db 6 dup(?)
    grid     db 64 dup('.')
    fuel     db 20
    fuelused db 0
    rrow     db 0
    rcol     db 0
    nrow     db 0
    ncol     db 0
    seqbuf   db 20 dup(0)
    seqlen   db 0
    msg1     db "MARS ROVER NAVIGATION SYSTEM", 13, 10, "$"
    msg2     db "Enter Student ID 1 (8 digits): $"
    msg3     db "Enter Student ID 2 (8 digits): $"
    msg4     db "Legend: [R]=Rover  [O]=Crater  [.]=Empty", 13, 10, "$"
    msg5     db "Battery Level: 20 Units", 13, 10, "$"
    msg6     db "Enter moves (U,D,L,R stop with invalid): $"
    msg7     db "Executing: $"
    msg8     db "Error: Boundary breach!", 13, 10, "$"
    msg9     db "CRITICAL FAILURE!", 13, 10, "$"
    msg10    db "Rover crashed at coordinates ($"
    msg11    db "Mission Aborted.", 13, 10, "$"
    msg12    db "Goodbye!", 13, 10, "$"
    msg13    db "MISSION SUCCESS!", 13, 10, "$"
    msg14    db "Rover reached coordinates: ($"
    msg15    db "Fuel Consumed: $"
    msg16    db "Remaining Battery Level: $"
    msg17    db " Units", 13, 10, "$"
    msg18    db 13, 10, "$"
    msgerr   db "Invalid input! Use only U,D,L,R. Try again.", 13, 10, "$"
ends

stack segment
    dw 128 dup(0)
ends

code segment
start:
    mov ax, data
    mov ds, ax

    call wipe
    lea dx, msg1
    call display

    lea dx, msg2
    call display
    lea si, uniid
    call getid

    lea dx, msg3
    call display
    lea si, uniid2
    call getid

    lea si, uniid
    add si, 7
    lea di, col
    call placemark
    lea si, uniid
    add si, 6
    lea di, row
    call placemark
    lea si, uniid2
    add si, 7
    lea di, col
    add di, 3
    call placemark
    lea si, uniid2
    add si, 6
    lea di, row
    add di, 3
    call placemark

    mov cx, 6
    xor bx, bx
gencraters:
    push cx
    push bx
    lea si, row
    mov al, [si+bx]
    xor ah, ah
    mov cl, 8
    mul cl
    pop bx
    push bx
    lea si, col
    add al, [si+bx]
    xor ah, ah
    mov dx, ax
    lea bx, grid
    add bx, dx
    mov [bx], 'O'
    pop bx
    inc bx
    pop cx
    loop gencraters

    lea bx, grid
findr:
    cmp [bx], 'O'
    je shift
    mov [bx], 'R'
    mov rrow, 0
    mov al, 0
    mov rcol, al
    jmp initdone
shift:
    inc bx
    jmp findr

initdone:
    call wipe
    lea dx, msg1
    call display
    lea dx, msg18
    call display
    call drawmap
    lea dx, msg4
    call display
    lea dx, msg5
    call display

getinput:
    lea dx, msg6
    call display
    xor bx, bx
readseq:
    mov ah, 01h
    int 21h
    cmp al, 'U'
    je seqok
    cmp al, 'u'
    je seqok
    cmp al, 'D'
    je seqok
    cmp al, 'd'
    je seqok
    cmp al, 'L'
    je seqok
    cmp al, 'l'
    je seqok
    cmp al, 'R'
    je seqok
    cmp al, 'r'
    je seqok
    jmp seqstop
seqok:
    lea si, seqbuf
    mov [si+bx], al
    inc bx
    cmp bx, 20
    jl readseq
seqstop:
    cmp al, 0Dh
    je seqend
    xor bx, bx
    mov seqlen, 0
    lea dx, msg18
    call display
    lea dx, msgerr
    call display
    jmp getinput
seqend:
    mov seqlen, bl
    lea dx, msg18
    call display
    cmp bl, 0
    je getinput
    call refresh
    xor bx, bx

execloop:
    cmp bl, seqlen
    je seqdone

    lea si, seqbuf
    mov al, [si+bx]
    push bx

    cmp al, 'U'
    je doup
    cmp al, 'u'
    je doup
    cmp al, 'D'
    je dodown
    cmp al, 'd'
    je dodown
    cmp al, 'L'
    je doleft
    cmp al, 'l'
    je doleft
    jmp doright

doup:
    mov al, rrow
    cmp al, 0
    je boundary
    dec al
    mov nrow, al
    mov al, rcol
    mov ncol, al
    jmp checkmove

dodown:
    mov al, rrow
    cmp al, 7
    je boundary
    inc al
    mov nrow, al
    mov al, rcol
    mov ncol, al
    jmp checkmove

doleft:
    mov al, rrow
    mov nrow, al
    mov al, rcol
    cmp al, 0
    je boundary
    dec al
    mov ncol, al
    jmp checkmove

doright:
    mov al, rrow
    mov nrow, al
    mov al, rcol
    cmp al, 7
    je boundary
    inc al
    mov ncol, al

checkmove:
    mov al, nrow
    mov bl, ncol
    xor ah, ah
    mov cl, 8
    mul cl
    xor bh, bh
    add ax, bx
    mov bx, ax
    lea si, grid
    add si, bx
    cmp [si], 'O'
    je collision

    mov al, rrow
    xor ah, ah
    mov cl, 8
    mul cl
    xor ah, ah
    add al, rcol
    mov bx, ax
    lea si, grid
    add si, bx
    mov [si], '.'

    mov al, nrow
    mov rrow, al
    mov al, ncol
    mov rcol, al

    mov al, nrow
    mov bl, ncol
    xor ah, ah
    mov cl, 8
    mul cl
    xor bh, bh
    add ax, bx
    mov bx, ax
    lea si, grid
    add si, bx
    mov [si], 'R'

    dec fuel
    inc fuelused

    call pause
    call refresh

    pop bx
    inc bx
    jmp execloop

boundary:
    pop bx
    call wipe
    lea dx, msg1
    call display
    call drawmap
    lea dx, msg8
    call display
    jmp exitprog

collision:
    mov al, nrow
    mov rrow, al
    mov al, ncol
    mov rcol, al
    mov al, nrow
    mov bl, ncol
    xor ah, ah
    mov cl, 8
    mul cl
    xor bh, bh
    add ax, bx
    mov bx, ax
    lea si, grid
    add si, bx
    mov [si], 'X'
    pop bx
    call wipe
    lea dx, msg1
    call display
    call drawmap
    mov dl, 07h
    mov ah, 02h
    int 21h
    lea dx, msg9
    call display
    lea dx, msg10
    call display
    call showpos
    lea dx, msg18
    call display
    lea dx, msg11
    call display
    jmp exitprog

seqdone:
    call wipe
    lea dx, msg1
    call display
    call drawmap
    lea dx, msg13
    call display
    lea dx, msg14
    call display
    call showpos
    lea dx, msg18
    call display
    lea dx, msg15
    call display
    mov al, fuelused
    call numout
    lea dx, msg18
    call display
    lea dx, msg16
    call display
    mov al, fuel
    call numout
    lea dx, msg17
    call display

exitprog:
    lea dx, msg12
    call display
    mov ax, 4c00h
    int 21h

display proc
    mov ah, 09h
    int 21h
    ret
display endp

getid proc
    mov cx, 8
idloop:
    mov ah, 01h
    int 21h
    mov [si], al
    inc si
    loop idloop
    lea dx, msg18
    call display
    ret
getid endp

showpos proc
    mov al, rrow
    call numout
    mov dl, ','
    mov ah, 02h
    int 21h
    mov al, rcol
    call numout
    mov dl, ')'
    mov ah, 02h
    int 21h
    ret
showpos endp

refresh proc
    call wipe
    lea dx, msg1
    call display
    lea dx, msg18
    call display
    lea dx, msg7
    call display
    push bx
    xor bx, bx
printloop:
    cmp bl, seqlen
    je printdone
    lea si, seqbuf
    mov dl, [si+bx]
    mov ah, 02h
    int 21h
    mov dl, ' '
    int 21h
    inc bx
    jmp printloop
printdone:
    pop bx
    lea dx, msg18
    call display
    lea dx, msg18
    call display
    call drawmap
    ret
refresh endp

numout proc
    xor ah, ah
    mov bl, 10
    div bl
    cmp al, 0
    je skiptens
    push ax
    mov dl, al
    add dl, 30h
    mov ah, 02h
    int 21h
    pop ax
skiptens:
    mov dl, ah
    add dl, 30h
    mov ah, 02h
    int 21h
    ret
numout endp

wipe proc
    mov ax, 0600h
    mov bh, 07h
    mov cx, 0000h
    mov dx, 184fh
    int 10h
    mov ah, 02h
    mov bh, 0
    mov dx, 0000h
    int 10h
    ret
wipe endp

pause proc
    mov cx, 0020h
dly:
    nop
    nop
    nop
    loop dly
    ret
pause endp

placemark proc
    mov cx, 3
l1:
    mov al, [si]
    sub al, 30h
    xor ah, ah
    mov bl, 8
    div bl
    mov [di], ah
    sub si, 2
    add di, 1
    loop l1
    ret
placemark endp

drawmap proc
    mov dl, ' '
    mov ah, 02h
    int 21h
    mov dl, ' '
    int 21h
    mov bx, 0
printcol:
    mov dl, bl
    add dl, 30h
    mov ah, 02h
    int 21h
    mov dl, ' '
    int 21h
    inc bx
    cmp bx, 8
    jl printcol
    mov dl, 13
    mov ah, 02h
    int 21h
    mov dl, 10
    int 21h
    lea si, grid
    mov bx, 0
lo1:
    mov dl, bl
    add dl, 30h
    mov ah, 02h
    int 21h
    mov dl, ' '
    int 21h
    mov cx, 8
lo2:
    mov dl, [si]
    mov ah, 02h
    int 21h
    mov dl, ' '
    int 21h
    inc si
    loop lo2
    mov dl, 13
    mov ah, 02h
    int 21h
    mov dl, 10
    int 21h
    inc bx
    cmp bx, 8
    jl lo1
    ret
drawmap endp

ends
end start
